---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NavBar from "@/components/NavBar.astro";
import TerminalFrame from "@/components/TerminalFrame.astro";
import PostCard from "@/components/PostCard.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog — Dmytro Khomenko" description="Infrastructure war stories, DevOps patterns, and lessons from the field.">
  <NavBar />
  <main class="blog-listing">

    <section class="blog-listing__header">
      <div class="blog-listing__header-inner">
        <div class="blog-listing__prompt">
          <span class="blog-listing__prompt-path">~/blog</span>
          <span class="blog-listing__prompt-sep">$</span>
          <span class="blog-listing__prompt-cmd">ls -lt --sort=date</span>
          <span class="blink blog-listing__cursor">▌</span>
        </div>
        <h1 class="blog-listing__title">FIELD NOTES</h1>
        <p class="blog-listing__subtitle">Infrastructure war stories, DevOps patterns, lessons from the field.</p>
      </div>
    </section>

    <div class="blog-listing__body">

      <aside class="blog-listing__sidebar">
        <TerminalFrame title="// TAGS">
          <div class="tag-list">
            <a href="/blog" class="tag-list__item tag-list__item--all">ALL POSTS <span class="tag-list__count">{posts.length}</span></a>
            {allTags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag-list__item">
                #{tag}
                <span class="tag-list__count">{posts.filter((p) => p.data.tags.includes(tag)).length}</span>
              </a>
            ))}
          </div>
        </TerminalFrame>

        <TerminalFrame title="// STATS">
          <div class="sidebar-stats">
            <div class="sidebar-stats__row">
              <span class="sidebar-stats__label">TOTAL POSTS</span>
              <span class="sidebar-stats__value">{posts.length}</span>
            </div>
            <div class="sidebar-stats__row">
              <span class="sidebar-stats__label">TOPICS</span>
              <span class="sidebar-stats__value">{allTags.length}</span>
            </div>
            <div class="sidebar-stats__row">
              <span class="sidebar-stats__label">LATEST</span>
              <span class="sidebar-stats__value">
                {posts[0]?.data.pubDate.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
              </span>
            </div>
          </div>
        </TerminalFrame>
      </aside>

      <section class="blog-listing__posts">
        <TerminalFrame title="// ALL POSTS" headerRight={`${posts.length} ENTRIES`}>
          <div class="posts-grid">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={`/blog/${post.slug}`}
              />
            ))}
          </div>
        </TerminalFrame>
      </section>

    </div>
    <SiteFooter />
  </main>
</BaseLayout>

<style>
  .blog-listing {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .blog-listing__header {
    border-bottom: 1px solid rgba(232, 130, 10, 0.15);
    margin-bottom: 40px;
    padding-bottom: 32px;
  }

  .blog-listing__header-inner {
    max-width: 700px;
  }

  .blog-listing__prompt {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    margin-bottom: 16px;
  }

  .blog-listing__prompt-path { color: var(--cyber-orange); }
  .blog-listing__prompt-sep  { color: var(--cyber-text-dim); }
  .blog-listing__prompt-cmd  { color: var(--cyber-text); }
  .blog-listing__cursor      { color: var(--cyber-orange); }

  .blog-listing__title {
    font-family: var(--font-sans);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    color: var(--cyber-text-bright);
    letter-spacing: 0.1em;
    margin: 0 0 8px;
  }

  .blog-listing__subtitle {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-text-dim);
    margin: 0;
    line-height: 1.6;
  }

  .blog-listing__body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    align-items: start;
  }

  .blog-listing__sidebar {
    position: sticky;
    top: 72px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Tag list */
  .tag-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tag-list__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--cyber-text-dim);
    text-decoration: none;
    padding: 4px 6px;
    border: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .tag-list__item:hover,
  .tag-list__item--all {
    color: var(--cyber-orange);
    border-color: rgba(232, 130, 10, 0.2);
  }

  .tag-list__count {
    color: var(--cyber-text-dim);
    font-size: 0.65rem;
  }

  .tag-list__item--all .tag-list__count {
    color: var(--cyber-orange);
  }

  /* Sidebar stats */
  .sidebar-stats {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-stats__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .sidebar-stats__label { color: var(--cyber-text-dim); letter-spacing: 0.06em; }
  .sidebar-stats__value { color: var(--cyber-orange); }

  /* Posts grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  @media (max-width: 900px) {
    .blog-listing__body {
      grid-template-columns: 1fr;
    }
    .blog-listing__sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }
    .blog-listing__sidebar > * {
      flex: 1;
      min-width: 180px;
    }
  }

  @media (max-width: 640px) {
    .blog-listing {
      padding: 24px 16px 60px;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
