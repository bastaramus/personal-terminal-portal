---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NavBar from "@/components/NavBar.astro";
import HeroProfile from "@/components/HeroProfile.astro";
import TerminalFrame from "@/components/TerminalFrame.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";

import QuotePanel from "@/components/QuotePanel.astro";
import SiteFooter from "@/components/SiteFooter.astro";

import { getCollection } from "astro:content";
import { projects } from "@/data/projects";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <NavBar />

  <main class="portal">
    <HeroProfile />

    <!-- Quote -->
    <section class="portal__section">
      <TerminalFrame title="// SYSTEM.QUOTE">
        <QuotePanel />
      </TerminalFrame>
    </section>

    <!-- Latest Posts -->
    <section class="portal__section" id="blog">
      <TerminalFrame title="// LATEST POSTS" headerRight={`${posts.length} ENTRIES`}>
        <div class="posts-grid">
          {
            posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={`/blog/${post.slug}`}
              />
            ))
          }
        </div>
      </TerminalFrame>
    </section>

    <!-- Projects -->
    <section class="portal__section" id="projects">
      <TerminalFrame title="// PROJECTS.DB" headerRight={`${projects.length} RECORDS`}>
        <div class="projects-grid">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </TerminalFrame>
    </section>

    <SiteFooter />
  </main>
</BaseLayout>


<style>
  .portal {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .portal__section {
    padding: 0 24px 24px;
  }

  /* Posts */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* ── Tablet (≤1024px): 4-col posts to 2-col ── */
  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile (≤640px): everything single column ── */
  @media (max-width: 640px) {
    .portal__section {
      padding: 0 12px 16px;
    }

    .posts-grid,
    .projects-grid {
      grid-template-columns: 1fr;
    }

  }
</style>
