---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NavBar from "@/components/NavBar.astro";
import HeroProfile from "@/components/HeroProfile.astro";
import TerminalFrame from "@/components/TerminalFrame.astro";
import PostCard from "@/components/PostCard.astro";
import SkillTag from "@/components/SkillTag.astro";
import CvTimeline from "@/components/CvTimeline.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import QuotePanel from "@/components/QuotePanel.astro";
import ContactPanel from "@/components/ContactPanel.astro";

import { getCollection } from "astro:content";
import { profile } from "@/data/profile";
import { skillCategories, certifications } from "@/data/skills";
import { projects } from "@/data/projects";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <NavBar />

  <main class="portal">
    <HeroProfile />

    <!-- Latest Posts -->
    <section class="portal__section" id="blog">
      <TerminalFrame title="// LATEST POSTS" headerRight={`${posts.length} ENTRIES`}>
        <div class="posts-grid">
          {
            posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={`/blog/${post.slug}`}
              />
            ))
          }
        </div>
      </TerminalFrame>
    </section>

    <!-- About / Experience / Skills -->
    <section class="portal__section portal__section--3col" id="about">
      <!-- About Me -->
      <TerminalFrame title="// ABOUT ME" class="about-panel">
        <div class="about-panel__body">
          <p class="about-panel__bio">{profile.bio}</p>
          <div class="about-panel__divider"></div>
          <div class="about-panel__rows">
            <div class="about-panel__row">
              <span class="about-panel__row-label">LOCATION</span>
              <span class="about-panel__row-value">{profile.location}</span>
            </div>
            <div class="about-panel__row">
              <span class="about-panel__row-label">STATUS</span>
              <span class="about-panel__row-value about-panel__row-value--green">{profile.status}</span>
            </div>
            <div class="about-panel__row">
              <span class="about-panel__row-label">FOCUS</span>
              <span class="about-panel__row-value">{profile.focus}</span>
            </div>
          </div>
        </div>
      </TerminalFrame>

      <!-- Experience -->
      <TerminalFrame title="// EXPERIENCE" class="experience-panel">
        <CvTimeline />
      </TerminalFrame>

      <!-- Skills -->
      <TerminalFrame title="// SKILLS" class="skills-panel">
        <div class="skills-body">
          {
            skillCategories.map((cat, i) => (
              <div class="skills-category">
                <div class="skills-category__label">{cat.label}</div>
                <div class="skills-category__tags">
                  {cat.skills.map((skill) => (
                    <SkillTag tag={skill} />
                  ))}
                </div>
                {i < skillCategories.length - 1 && (
                  <div class="skills-divider" />
                )}
              </div>
            ))
          }
          <div class="skills-divider" />
          <div class="skills-category">
            <div class="skills-category__label">CERTS</div>
            <div class="skills-certs">
              {
                certifications.map((cert) => (
                  <div class="skills-cert">
                    <span class="skills-cert__label">{cert.label}</span>
                    <span class="skills-cert__year">{cert.year}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </TerminalFrame>
    </section>

    <!-- Projects -->
    <section class="portal__section" id="projects">
      <TerminalFrame title="// PROJECTS.DB" headerRight={`${projects.length} RECORDS`}>
        <div class="projects-grid">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </TerminalFrame>
    </section>

    <!-- Quote + Contact -->
    <section class="portal__section portal__section--2col" id="contact">
      <TerminalFrame title="// SYSTEM.QUOTE">
        <QuotePanel />
      </TerminalFrame>
      <TerminalFrame title="// CONTACT">
        <ContactPanel />
      </TerminalFrame>
    </section>

    <footer class="portal__footer">
      <span>root@xomenko.com</span>
      <span class="portal__footer-sep">|</span>
      <span>built with astro + love for the terminal</span>
      <span class="portal__footer-sep">|</span>
      <span>{new Date().getFullYear()}</span>
    </footer>
  </main>
</BaseLayout>

<style>
  .portal {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .portal__section {
    padding: 0 24px 24px;
  }

  /* 3-column row: about / experience / skills */
  .portal__section--3col {
    display: grid;
    grid-template-columns: 340px 1fr 500px;
    gap: 16px;
    padding: 0 24px 24px;
    align-items: start;
  }

  /* 2-column row: quote / contact */
  .portal__section--2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 0 24px 24px;
    align-items: start;
  }

  /* Posts */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  /* About panel */
  .about-panel__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-panel__bio {
    font-size: 0.7rem;
    color: var(--cyber-text);
    line-height: 1.75;
    margin: 0;
  }

  .about-panel__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 130, 10, 0.35), transparent);
  }

  .about-panel__rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .about-panel__row {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .about-panel__row-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.1em;
  }

  .about-panel__row-value {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--cyber-text);
  }

  .about-panel__row-value--green {
    color: var(--cyber-green);
  }

  /* Skills */
  .skills-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .skills-category {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .skills-category__label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.12em;
  }

  .skills-category__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .skills-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 130, 10, 0.35), transparent);
    margin: 10px 0;
  }

  .skills-certs {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .skills-cert {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .skills-cert__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--cyber-text);
  }

  .skills-cert__year {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--cyber-text-dim);
  }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Footer */
  .portal__footer {
    margin: 0 24px;
    padding: 12px 0 24px;
    border-top: 1px solid rgba(232, 130, 10, 0.15);
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--cyber-text-dim);
  }

  .portal__footer-sep {
    color: rgba(232, 130, 10, 0.3);
  }
</style>
