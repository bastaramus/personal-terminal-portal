---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NavBar from "@/components/NavBar.astro";
import HeroProfile from "@/components/HeroProfile.astro";
import TerminalFrame from "@/components/TerminalFrame.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";

import { getCollection } from "astro:content";
import { projects } from "@/data/projects";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const footerEmailEncoded = Buffer.from("root@xomenko.com").toString("base64");
---

<BaseLayout>
  <NavBar />

  <main class="portal">
    <HeroProfile />

    <!-- Latest Posts -->
    <section class="portal__section" id="blog">
      <TerminalFrame title="// LATEST POSTS" headerRight={`${posts.length} ENTRIES`}>
        <div class="posts-grid">
          {
            posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                href={`/blog/${post.slug}`}
              />
            ))
          }
        </div>
      </TerminalFrame>
    </section>

    <!-- Projects -->
    <section class="portal__section" id="projects">
      <TerminalFrame title="// PROJECTS.DB" headerRight={`${projects.length} RECORDS`}>
        <div class="projects-grid">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </TerminalFrame>
    </section>

    <footer class="portal__footer">
      <span data-e={footerEmailEncoded}></span>
      <span class="portal__footer-sep">|</span>
      <span>built with astro + love for the terminal</span>
      <span class="portal__footer-sep">|</span>
      <span>{new Date().getFullYear()}</span>
    </footer>
  </main>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>('footer [data-e], .portal__footer [data-e]').forEach((el) => {
    el.textContent = atob(el.dataset.e!);
  });
</script>

<style>
  .portal {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .portal__section {
    padding: 0 24px 24px;
  }

  /* Posts */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  /* Projects */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  /* Footer */
  .portal__footer {
    margin: 0 24px;
    padding: 12px 0 24px;
    border-top: 1px solid rgba(232, 130, 10, 0.15);
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.73rem;
    color: var(--cyber-text-dim);
  }

  .portal__footer-sep {
    color: rgba(232, 130, 10, 0.3);
  }

  /* ── Tablet (≤1024px): 4-col posts to 2-col ── */
  @media (max-width: 1024px) {
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile (≤640px): everything single column ── */
  @media (max-width: 640px) {
    .portal__section {
      padding: 0 12px 16px;
    }

    .posts-grid,
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .portal__footer {
      margin: 0 12px;
      flex-wrap: wrap;
      gap: 6px;
    }
  }
</style>
