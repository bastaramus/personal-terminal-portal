---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NavBar from "@/components/NavBar.astro";
import TerminalFrame from "@/components/TerminalFrame.astro";
import SkillTag from "@/components/SkillTag.astro";
import CvTimeline from "@/components/CvTimeline.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { profile } from "@/data/profile";
import { skillCategories } from "@/data/skills";
const promptUserEncoded = Buffer.from("root@xomenko.com").toString("base64");

const contactIcons: Record<string, string> = {
  LinkedIn: `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  Telegram: `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
  Email: `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`,
};
const contacts = profile.socials.map((s) => ({
  ...s,
  icon: contactIcons[s.label] ?? "",
  encoded: s.href.startsWith("mailto:") ? Buffer.from(s.value).toString("base64") : null,
}));
---

<BaseLayout title="About Me — Dmytro Khomenko" description="DevOps engineer, team lead. AWS cloud, hybrid infrastructure, Kubernetes, Terraform. Based in Kyiv.">
  <NavBar />
  <main class="about-page">

    <section class="about-page__header">
      <div class="about-page__prompt">
        <span class="about-page__prompt-user" data-e={promptUserEncoded}></span>
        <span class="about-page__prompt-path">:~$</span>
        <span class="about-page__prompt-cmd">whoami</span>
        <span class="blink about-page__cursor">▌</span>
      </div>
      <h1 class="about-page__title">ABOUT ME</h1>
      <div class="about-page__subtitles">
        <span>DEVOPS ARCHITECT</span>
        <span class="about-page__subtitle-sep">/</span>
        <span>PLATFORM ENGINEER</span>
        <span class="about-page__subtitle-sep">/</span>
        <span>TEAM LEAD</span>
      </div>
    </section>

    <!-- About Me — full width -->
    <div class="about-page__row">
      <TerminalFrame title="// ABOUT ME">
        <div class="about-panel__body">
          <div class="about-panel__section-label">SUMMARY</div>
          <div class="about-panel__text" id="about-text">
            {profile.aboutParagraphs.map((p, i) => (
              i === profile.aboutParagraphs.length - 1
                ? <p class="about-panel__bio" set:html={p.replace('grab my CV', 'grab my <a class="about-panel__cv-link" href="/cv.pdf" target="_blank" rel="noopener">CV</a>')} />
                : <p class="about-panel__bio">{p}</p>
            ))}
          </div>
          <button class="about-panel__expand-btn" id="about-expand-btn" aria-expanded="false">
            <span id="about-expand-label">▼ READ MORE</span>
          </button>
          <div class="about-panel__divider"></div>
          <div class="about-panel__bottom">
            <div class="about-panel__rows">
              <div class="about-panel__row">
                <span class="about-panel__row-label">
                  <svg class="about-panel__row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                    <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                  </svg>
                  LOCATION
                </span>
                <span class="about-panel__row-value">{profile.location}</span>
              </div>
              <div class="about-panel__row">
                <span class="about-panel__row-label">
                  <svg class="about-panel__row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/>
                  </svg>
                  LANGUAGES
                </span>
                <div class="about-panel__languages">
                  {profile.languages.map((lang) => (
                    <span class="about-panel__lang">
                      <span class="about-panel__lang-name">{lang.label}</span>
                      <span class="about-panel__lang-level">{lang.level}</span>
                    </span>
                  ))}
                </div>
              </div>
              <div class="about-panel__row">
                <span class="about-panel__row-label">
                  <svg class="about-panel__row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/>
                  </svg>
                  STATUS
                </span>
                <span class="about-panel__row-value about-panel__row-value--green">{profile.status}</span>
              </div>
              <div class="about-panel__row">
                <span class="about-panel__row-label">
                  <svg class="about-panel__row-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z"/>
                  </svg>
                  FOCUS
                </span>
                <span class="about-panel__row-value">{profile.focus}</span>
              </div>
            </div>

            <div class="about-panel__edu">
              <div class="about-panel__section-label">CONTACT</div>
              <div class="about-contact-strip about-contact-strip--column">
                {contacts.map((s) =>
                  s.encoded ? (
                    <a href="#" class="about-contact-strip__item" data-contact-e={s.encoded}>
                      <span class="about-contact-strip__icon" set:html={s.icon} />
                      <span class="about-contact-strip__label">{s.label}</span>
                      <span class="about-contact-strip__value" data-contact-text></span>
                    </a>
                  ) : (
                    <a href={s.href} class="about-contact-strip__item" target="_blank" rel="noopener">
                      <span class="about-contact-strip__icon" set:html={s.icon} />
                      <span class="about-contact-strip__label">{s.label}</span>
                      <span class="about-contact-strip__value">{s.value}</span>
                    </a>
                  )
                )}
              </div>
            </div>
          </div>
        </div>
      </TerminalFrame>
    </div>

    {/* Experience — hidden until ready
    <div class="about-page__row">
      <TerminalFrame title="// EXPERIENCE">
        <CvTimeline />
      </TerminalFrame>
    </div>
    */}

    <!-- Skills — full width -->
    <div class="about-page__row">
      <TerminalFrame title="// SKILLS">
        <div class="skills-body">
          {skillCategories.map((cat, i) => (
            <div class="skills-category">
              <div class="skills-category__label">{cat.label}</div>
              <div class="skills-category__tags">
                {cat.skills.map((skill) => (
                  <SkillTag tag={skill} />
                ))}
              </div>
              {i < skillCategories.length - 1 && <div class="skills-divider" />}
            </div>
          ))}
        </div>
      </TerminalFrame>
    </div>

    <SiteFooter />

  </main>
<script>
  document.querySelectorAll<HTMLElement>('.about-page__prompt-user[data-e]').forEach((el) => {
    el.textContent = atob(el.dataset.e!);
  });

  document.querySelectorAll<HTMLAnchorElement>('.about-contact-strip__item[data-contact-e]').forEach((el) => {
    const email = atob(el.dataset.contactE!);
    el.href = 'mailto:' + email;
    const text = el.querySelector('[data-contact-text]');
    if (text) text.textContent = email;
  });

  const text = document.getElementById('about-text')!;
  const btn = document.getElementById('about-expand-btn')!;
  const label = document.getElementById('about-expand-label')!;

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    if (expanded) {
      text.classList.remove('about-panel__text--expanded');
      btn.setAttribute('aria-expanded', 'false');
      label.textContent = '▼ READ MORE';
    } else {
      text.classList.add('about-panel__text--expanded');
      btn.setAttribute('aria-expanded', 'true');
      label.textContent = '▲ COLLAPSE';
    }
  });
</script>

</BaseLayout>

<style>
  .about-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-page__header {
    border-bottom: 1px solid rgba(232, 130, 10, 0.15);
    padding-bottom: 28px;
  }

  .about-page__prompt {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    margin-bottom: 14px;
  }

  .about-page__prompt-user { color: var(--cyber-orange); }
  .about-page__prompt-path { color: var(--cyber-text-dim); }
  .about-page__prompt-sep  { color: var(--cyber-text-dim); }
  .about-page__prompt-cmd  { color: var(--cyber-text); }
  .about-page__cursor      { color: var(--cyber-orange); }

  .about-page__title {
    font-family: var(--font-sans);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900;
    color: var(--cyber-text-bright);
    letter-spacing: 0.1em;
    margin: 0 0 6px;
  }

  .about-page__subtitles {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-orange);
    letter-spacing: 0.12em;
    margin: 0;
  }

  .about-page__subtitle-sep {
    color: rgba(232, 130, 10, 0.35);
    font-size: 0.75rem;
  }

  /* Rows */
  .about-page__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    align-items: start;
  }

  /* About panel */
  .about-panel__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-panel__section-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.12em;
  }

  .about-panel__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
    max-height: 5.6em; /* show ~2 lines of first paragraph */
    transition: max-height 0.4s ease;
    -webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 50%, transparent 100%);
  }

  .about-panel__text--expanded {
    max-height: 1000px;
    -webkit-mask-image: none;
    mask-image: none;
  }

  .about-panel__expand-btn {
    align-self: flex-start;
    background: none;
    border: 1px solid rgba(232, 130, 10, 0.3);
    color: var(--cyber-orange);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    padding: 4px 14px;
    cursor: pointer;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .about-panel__expand-btn:hover {
    background: rgba(232, 130, 10, 0.07);
    box-shadow: 0 0 8px rgba(232, 130, 10, 0.15);
  }

  .about-panel__bio {
    font-size: 0.875rem;
    color: var(--cyber-text);
    line-height: 1.75;
    margin: 0;
  }

  :global(.about-panel__cv-link) {
    color: var(--cyber-orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 130, 10, 0.4);
    transition: border-color 0.15s, color 0.15s;
  }

  :global(.about-panel__cv-link:hover) {
    color: var(--cyber-text-bright);
    border-bottom-color: var(--cyber-orange);
  }

  .about-panel__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 130, 10, 0.35), transparent);
  }

  .about-panel__bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: start;
  }

  .about-panel__edu {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-left: 1px solid rgba(232, 130, 10, 0.15);
    padding-left: 24px;
  }

  .about-panel__rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .about-panel__row {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .about-panel__row-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .about-panel__row-icon {
    width: 12px;
    height: 12px;
    color: var(--cyber-orange);
    flex-shrink: 0;
  }

  .about-panel__row-value {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-text);
  }

  .about-panel__row-value--green {
    color: var(--cyber-green);
  }

  .about-panel__languages {
    display: flex;
    flex-wrap: wrap;
    gap: 0 16px;
    margin-top: 2px;
  }

  .about-panel__lang {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
  }

  .about-panel__lang-name {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-text);
    letter-spacing: 0.06em;
  }

  .about-panel__lang-level {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.08em;
  }

  /* Contact strip */
  .about-contact-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .about-contact-strip__item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 14px 6px 10px;
    background: rgba(13, 13, 13, 0.5);
    border: 1px solid rgba(232, 130, 10, 0.15);
    text-decoration: none;
    flex: 1;
    min-width: 200px;
    transition: border-color 0.15s, background 0.15s;
  }

  .about-contact-strip__item:hover {
    border-color: rgba(232, 130, 10, 0.4);
    background: rgba(232, 130, 10, 0.05);
  }

  .about-contact-strip__icon {
    display: flex;
    align-items: center;
    color: var(--cyber-text-dim);
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .about-contact-strip__item:hover .about-contact-strip__icon {
    color: var(--cyber-orange);
  }

  .about-contact-strip__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.1em;
    flex-shrink: 0;
    width: 60px;
  }

  .about-contact-strip__value {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--cyber-text);
    flex: 1;
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }

  .about-contact-strip__item:hover .about-contact-strip__value {
    color: var(--cyber-orange);
  }

  /* Skills */
  .skills-body {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0 24px;
  }

  .skills-category {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 10px 0;
  }

  .skills-category__label {
    font-family: var(--font-mono);
    font-size: 0.73rem;
    color: var(--cyber-text-dim);
    letter-spacing: 0.12em;
  }

  .skills-category__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .skills-divider {
    display: none;
  }

  .about-contact-strip--column {
    flex-direction: column;
    gap: 6px;
  }

  .about-contact-strip--column .about-contact-strip__item {
    min-width: unset;
    flex: unset;
  }

  @media (max-width: 768px) {
    .about-panel__bottom {
      grid-template-columns: 1fr;
    }
    .about-panel__edu {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid rgba(232, 130, 10, 0.15);
      padding-top: 16px;
    }
  }

  @media (max-width: 640px) {
    .about-page {
      padding: 24px 16px 60px;
    }
    .skills-body {
      grid-template-columns: 1fr;
    }
  }
</style>
