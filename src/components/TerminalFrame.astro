---
interface Props {
  title: string;
  class?: string;
  headerRight?: string;
}

const { title, class: className = "", headerRight } = Astro.props;
---

<div class:list={["terminal-frame", className]}>
  <div class="terminal-frame__header">
    <span class="terminal-frame__title">{title}</span>
    {headerRight && <span class="terminal-frame__header-right">{headerRight}</span>}
  </div>
  <div class="terminal-frame__body">
    <slot />
  </div>
</div>

<style>
  .terminal-frame {
    position: relative;
    background: var(--cyber-panel);
    border: 1px solid var(--cyber-orange-dim);
    display: flex;
    flex-direction: column;
  }

  /* Corner accents */
  .terminal-frame::before,
  .terminal-frame::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 10px;
    pointer-events: none;
  }
  .terminal-frame::before {
    top: -1px;
    left: -1px;
    border-top: 2px solid var(--cyber-orange);
    border-left: 2px solid var(--cyber-orange);
  }
  .terminal-frame::after {
    bottom: -1px;
    right: -1px;
    border-bottom: 2px solid var(--cyber-orange);
    border-right: 2px solid var(--cyber-orange);
  }

  .terminal-frame__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 12px;
    background: rgba(232, 130, 10, 0.04);
    border-bottom: 1px solid var(--cyber-orange-dim);
    gap: 8px;
  }

  .terminal-frame__title {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--cyber-orange);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .terminal-frame__header-right {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--cyber-text-dim);
  }

  .terminal-frame__body {
    flex: 1;
    padding: 16px;
  }
</style>
