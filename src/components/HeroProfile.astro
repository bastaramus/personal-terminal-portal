---
import { profile } from "@/data/profile";
import ContactPanel from "@/components/ContactPanel.astro";
const promptUserEncoded = Buffer.from("root@xomenko.com").toString("base64");
---

<section class="hero">
  <!-- Background city image -->
  <div class="hero__bg"></div>
  <!-- Gradient overlays -->
  <div class="hero__gradient-h"></div>
  <div class="hero__gradient-v"></div>
  <!-- Scan animation -->
  <div class="hero__scan"></div>

  <div class="hero__inner">
    <!-- Avatar column -->
    <div class="hero__avatar-col">
      <div class="hero__avatar-frame">
        <!-- Corner accents -->
        <span class="hero__corner hero__corner--tl"></span>
        <span class="hero__corner hero__corner--tr"></span>
        <span class="hero__corner hero__corner--bl"></span>
        <span class="hero__corner hero__corner--br"></span>

        <img src="/avatar.png" alt="Dmytro Khomenko" class="hero__avatar-img" />
        <div class="hero__avatar-scan"></div>
      </div>

      <div class="hero__avatar-links">
        <a href="https://github.com/bastaramus" class="hero__avatar-link" target="_blank" rel="noopener" aria-label="GitHub">
          <!-- GitHub icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/dmytro-khomenko-9221031a4" class="hero__avatar-link" target="_blank" rel="noopener" aria-label="LinkedIn">
          <!-- LinkedIn icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <button class="hero__avatar-link" id="tg-qr-btn" aria-label="Telegram QR">
          <!-- Telegram icon -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Telegram QR modal -->
    <div class="ssh-modal" id="tg-qr-modal" aria-hidden="true">
      <div class="ssh-modal__box">
        <div class="ssh-modal__header">
          <span class="ssh-modal__title">// TELEGRAM</span>
          <button class="ssh-modal__close" id="tg-qr-modal-close" aria-label="Close">✕</button>
        </div>
        <div class="ssh-modal__body tg-qr-body">
          <p class="ssh-modal__hint">Scan to open <a href="https://t.me/khomenko_dmytro" target="_blank" rel="noopener" class="tg-qr__handle">@khomenko_dmytro</a> on Telegram</p>
          <img src="/tg-qr.png" alt="Telegram QR code" class="tg-qr__img" />
        </div>
      </div>
    </div>

    <!-- Content column -->
    <div class="hero__content">
      <div class="hero__prompt">
        <div class="hero__prompt-line1">
          <span class="hero__prompt-user" data-e={promptUserEncoded}></span>
          <span class="hero__prompt-sep">:~$</span>
        </div>
        <div class="hero__prompt-line2">
          <span class="hero__prompt-cmd">./display --user-info</span>
          <span class="blink hero__prompt-cursor">▌</span>
        </div>
      </div>

      <h1 class="hero__name flicker">
        {profile.name.first}<br />
        <span class="hero__name-last">{profile.name.last}</span>
      </h1>

      <div class="hero__title-row">
        <span class="hero__title-line"></span>
        <span class="hero__title-text">{profile.title}</span>
        <span class="hero__title-line"></span>
      </div>

      <div class="hero__ctas">
        <a href="/cv.pdf" class="hero__cta hero__cta--accent" download="Dmytro_Khomenko_CV.pdf">
          <span>↓</span> DOWNLOAD CV
        </a>
        <button class="hero__cta hero__cta--accent" id="contact-modal-btn">
          <span>✉</span> INIT CONTACT
        </button>
        <button class="hero__cta hero__cta--primary" id="ssh-key-btn">
          <span>$</span> GET SSH KEY
        </button>
      </div>

      <!-- Contact modal -->
      <div class="ssh-modal" id="contact-modal" aria-hidden="true">
        <div class="ssh-modal__box">
          <div class="ssh-modal__header">
            <span class="ssh-modal__title">// CONTACT</span>
            <button class="ssh-modal__close" id="contact-modal-close" aria-label="Close">✕</button>
          </div>
          <div class="ssh-modal__body">
            <ContactPanel />
          </div>
        </div>
      </div>

      <!-- SSH key modal -->
      <div class="ssh-modal" id="ssh-modal" aria-hidden="true">
        <div class="ssh-modal__box">
          <div class="ssh-modal__header">
            <span class="ssh-modal__title">// SSH.PUBLIC_KEY</span>
            <button class="ssh-modal__close" id="ssh-modal-close" aria-label="Close">✕</button>
          </div>
          <div class="ssh-modal__body">
            <p class="ssh-modal__hint">Add to <code>~/.ssh/authorized_keys</code> or share-access dialog</p>
            <pre class="ssh-modal__key" id="ssh-key-text">ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDYZThIXy1W2N3EcU1KRSB+Q425vRr5x7AMEVU5ukJmm dmytro-khomenko</pre>
            <button class="ssh-modal__copy" id="ssh-copy-btn">
              <span id="ssh-copy-label">⎘ COPY KEY</span>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.hero__prompt-user[data-e]').forEach((el) => {
    el.textContent = atob(el.dataset.e!);
  });

  // Contact modal
  const contactModal = document.getElementById('contact-modal')!;
  document.getElementById('contact-modal-btn')!.addEventListener('click', () => {
    contactModal.setAttribute('aria-hidden', 'false');
    contactModal.classList.add('ssh-modal--open');
  });
  const closeContact = () => {
    contactModal.setAttribute('aria-hidden', 'true');
    contactModal.classList.remove('ssh-modal--open');
  };
  document.getElementById('contact-modal-close')!.addEventListener('click', closeContact);
  contactModal.addEventListener('click', (e) => { if (e.target === contactModal) closeContact(); });

  // SSH key modal
  const modal = document.getElementById('ssh-modal')!;
  const openBtn = document.getElementById('ssh-key-btn')!;
  const closeBtn = document.getElementById('ssh-modal-close')!;
  const copyBtn = document.getElementById('ssh-copy-btn')!;
  const copyLabel = document.getElementById('ssh-copy-label')!;
  const keyText = document.getElementById('ssh-key-text')!;

  openBtn.addEventListener('click', () => {
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('ssh-modal--open');
  });

  const closeModal = () => {
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('ssh-modal--open');
  };

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  // Telegram QR modal
  const tgQrModal = document.getElementById('tg-qr-modal')!;
  document.getElementById('tg-qr-btn')!.addEventListener('click', () => {
    tgQrModal.setAttribute('aria-hidden', 'false');
    tgQrModal.classList.add('ssh-modal--open');
  });
  const closeTgQr = () => {
    tgQrModal.setAttribute('aria-hidden', 'true');
    tgQrModal.classList.remove('ssh-modal--open');
  };
  document.getElementById('tg-qr-modal-close')!.addEventListener('click', closeTgQr);
  tgQrModal.addEventListener('click', (e) => { if (e.target === tgQrModal) closeTgQr(); });

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeModal(); closeContact(); closeTgQr(); } });

  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(keyText.textContent!.trim()).then(() => {
      copyLabel.textContent = '✓ COPIED';
      setTimeout(() => { copyLabel.textContent = '⎘ COPY KEY'; }, 2000);
    });
  });
</script>

<style>
  .hero {
    position: relative;
    min-height: 420px;
    overflow: hidden;
    border-bottom: 1px solid rgba(232, 130, 10, 0.2);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: url("https://images.unsplash.com/photo-1672872476232-da16b45c9001?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixlib=rb-4.1.0&q=80&w=1080");
    background-size: cover;
    background-position: center 60%;
    filter: brightness(0.18) saturate(1.5) hue-rotate(200deg);
  }

  .hero__gradient-h {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(10, 12, 20, 0.98) 40%,
      rgba(10, 12, 20, 0.7) 70%,
      rgba(10, 12, 20, 0.4) 100%
    );
  }

  .hero__gradient-v {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(10, 12, 20, 1) 0%, transparent 60%);
  }

  .hero__scan {
    position: absolute;
    top: 0;
    left: 0;
    width: 30%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(232, 130, 10, 0.06),
      transparent
    );
    animation: scan 4s linear infinite;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 24px 40px;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: stretch;
  }

  /* Avatar */
  .hero__avatar-col {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero__avatar-frame {
    position: relative;
    width: 240px;
    height: 300px;
    border: 1px solid rgba(232, 130, 10, 0.5);
    box-shadow: 0 0 20px rgba(232, 130, 10, 0.2), inset 0 0 20px rgba(232, 130, 10, 0.05);
  }

  .hero__corner {
    position: absolute;
    width: 16px;
    height: 16px;
  }
  .hero__corner--tl { top: -2px; left: -2px; border-top: 2px solid var(--cyber-orange); border-left: 2px solid var(--cyber-orange); }
  .hero__corner--tr { top: -2px; right: -2px; border-top: 2px solid var(--cyber-orange); border-right: 2px solid var(--cyber-orange); }
  .hero__corner--bl { bottom: -2px; left: -2px; border-bottom: 2px solid var(--cyber-orange); border-left: 2px solid var(--cyber-orange); }
  .hero__corner--br { bottom: -2px; right: -2px; border-bottom: 2px solid var(--cyber-orange); border-right: 2px solid var(--cyber-orange); }

  .hero__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__avatar-scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(232, 130, 10, 0.03) 3px,
      rgba(232, 130, 10, 0.03) 4px
    );
    pointer-events: none;
  }

  .hero__avatar-status {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    background: rgba(10, 12, 20, 0.9);
    border: 1px solid rgba(232, 130, 10, 0.3);
    padding: 4px 8px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hero__status-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cyber-green);
    box-shadow: 0 0 6px var(--cyber-green);
    flex-shrink: 0;
  }

  .hero__status-text {
    font-size: 0.95rem;
    color: var(--cyber-orange);
    letter-spacing: 0.1em;
  }

  .hero__avatar-links {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    width: 240px;
  }

  .hero__avatar-link {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    background: rgba(17, 17, 17, 0.9);
    border: 1px solid rgba(232, 130, 10, 0.25);
    color: var(--cyber-text-dim);
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s, border-color 0.15s, box-shadow 0.15s;
  }

  .hero__avatar-link:hover {
    color: var(--cyber-orange);
    border-color: var(--cyber-orange-dim);
    box-shadow: 0 0 10px rgba(232, 130, 10, 0.2);
  }

  /* Content */
  .hero__content {
    display: flex;
    flex-direction: column;
  }

  .hero__ctas {
    margin-top: auto;
    padding-top: 28px;
  }

  .hero__prompt {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    font-size: 0.875rem;
    flex-wrap: nowrap;
  }

  .hero__prompt-line1,
  .hero__prompt-line2 {
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .hero__prompt {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }
  }

  .hero__prompt-user { color: var(--cyber-orange); }
  .hero__prompt-sep { color: var(--cyber-text-dim); }
  .hero__prompt-cmd { color: var(--cyber-orange); }
  .hero__prompt-cursor { color: var(--cyber-orange); }

  .hero__name {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: 0.06em;
    line-height: 1.1;
    margin-bottom: 8px;
    text-shadow: 0 0 30px rgba(232, 130, 10, 0.3), 0 0 60px rgba(232, 130, 10, 0.1);
    position: relative;
  }

  .hero__name::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--scanlines);
    pointer-events: none;
    z-index: 1;
  }

  .hero__name-last {
    color: var(--cyber-orange);
  }

  .hero__title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .hero__title-line {
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--cyber-orange);
  }

  .hero__title-text {
    color: var(--cyber-orange);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    letter-spacing: 0.2em;
    text-shadow: 0 0 8px rgba(232, 130, 10, 0.4);
  }

  .hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 26px;
    font-size: 0.88rem;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
    border: 1px solid rgba(232, 130, 10, 0.3);
    color: var(--cyber-orange);
    background: rgba(232, 130, 10, 0.05);
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }

  .hero__cta:hover {
    background: rgba(232, 130, 10, 0.1);
    box-shadow: 0 0 14px rgba(232, 130, 10, 0.25);
  }

  .hero__cta--accent {
    border-color: rgba(232, 130, 10, 0.6);
    color: var(--cyber-orange);
    background: rgba(232, 130, 10, 0.08);
    box-shadow: 0 0 10px rgba(232, 130, 10, 0.15);
  }

  .hero__cta--accent:hover {
    background: rgba(232, 130, 10, 0.15);
    box-shadow: 0 0 20px rgba(232, 130, 10, 0.35);
    border-color: var(--cyber-orange);
  }

  .hero__cta--primary {
    border-color: var(--cyber-orange);
    color: var(--cyber-bg);
    background: var(--cyber-orange);
    box-shadow: 0 0 18px rgba(232, 130, 10, 0.5);
  }

  .hero__cta--primary:hover {
    box-shadow: 0 0 30px rgba(232, 130, 10, 0.7);
    background: var(--cyber-orange);
  }

  .hero__socials {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .hero__social {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.82rem;
    color: var(--cyber-text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero__social:hover {
    color: var(--cyber-orange);
  }

  .hero__social-label {
    color: var(--cyber-text-dim);
  }

  .hero__social-value {
    color: inherit;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .hero__inner {
      grid-template-columns: 220px 1fr;
      gap: 28px;
      padding: 40px 24px 32px;
    }

    .hero__avatar-frame {
      width: 200px;
      height: 250px;
    }

    .hero__avatar-links {
      width: 200px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding: 32px 16px 24px;
      gap: 24px;
      justify-items: center;
      text-align: center;
      align-items: start;
    }

    .hero__avatar-col {
      justify-content: center;
    }

    .hero__content {
      width: 100%;
    }

    .hero__ctas {
      padding-top: 20px;
      margin-top: 0;
    }

    .hero__avatar-frame {
      width: 160px;
      height: 200px;
    }

    .hero__avatar-links {
      width: 160px;
    }

    .hero__title-row {
      justify-content: center;
    }

    .hero__ctas {
      justify-content: center;
    }

    .hero__socials {
      justify-content: center;
    }
  }

  /* SSH key modal */
  .ssh-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .ssh-modal--open {
    display: flex;
  }

  .ssh-modal__box {
    background: var(--cyber-panel);
    border: 1px solid var(--cyber-orange-dim);
    width: 100%;
    max-width: 580px;
    position: relative;
  }

  .ssh-modal__box::before {
    content: "";
    position: absolute;
    top: -1px; left: -1px;
    width: 12px; height: 12px;
    border-top: 2px solid var(--cyber-orange);
    border-left: 2px solid var(--cyber-orange);
  }

  .ssh-modal__box::after {
    content: "";
    position: absolute;
    bottom: -1px; right: -1px;
    width: 12px; height: 12px;
    border-bottom: 2px solid var(--cyber-orange);
    border-right: 2px solid var(--cyber-orange);
  }

  .ssh-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(232, 130, 10, 0.04);
    border-bottom: 1px solid var(--cyber-orange-dim);
    position: relative;
  }

  .ssh-modal__header::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--scanlines);
    pointer-events: none;
  }

  .ssh-modal__title {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-orange);
    letter-spacing: 0.08em;
  }

  .ssh-modal__close {
    background: none;
    border: none;
    color: var(--cyber-text-dim);
    font-size: 0.9rem;
    cursor: pointer;
    padding: 0 2px;
    line-height: 1;
    transition: color 0.15s;
  }

  .ssh-modal__close:hover {
    color: var(--cyber-orange);
  }

  .ssh-modal__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ssh-modal__hint {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--cyber-text-dim);
    margin: 0;
  }

  .ssh-modal__hint code {
    color: var(--cyber-orange);
  }

  .ssh-modal__key {
    font-family: var(--font-mono);
    font-size: 0.78rem;
