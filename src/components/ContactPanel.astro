---
import { profile } from "@/data/profile";

const icons: Record<string, string> = {
  LinkedIn: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  Telegram: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
  Email: `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>`,
};

const socials = profile.socials.map((s) => ({
  ...s,
  icon: icons[s.label] ?? "",
  encoded: s.href.startsWith("mailto:")
    ? Buffer.from(s.value).toString("base64")
    : null,
}));
---

<div class="contact-panel">
  {
    socials.map((s) =>
      s.encoded ? (
        <a href="#" class="contact-panel__row" data-e={s.encoded}>
          <span class="contact-panel__icon" set:html={s.icon} />
          <span class="contact-panel__platform">{s.label}</span>
          <span class="contact-panel__arrow">-&gt;</span>
          <span class="contact-panel__value" data-email-text></span>
        </a>
      ) : (
        <a href={s.href} class="contact-panel__row" target="_blank" rel="noopener">
          <span class="contact-panel__icon" set:html={s.icon} />
          <span class="contact-panel__platform">{s.label}</span>
          <span class="contact-panel__arrow">-&gt;</span>
          <span class="contact-panel__value">{s.value}</span>
        </a>
      )
    )
  }
</div>

<script>
  function initContactPanel() {
    document.querySelectorAll<HTMLAnchorElement>('.contact-panel__row[data-e]').forEach((el) => {
      const email = atob(el.dataset.e!);
      el.href = 'mailto:' + email;
      const text = el.querySelector('[data-email-text]');
      if (text) text.textContent = email;
    });
  }

  document.addEventListener('astro:page-load', initContactPanel);
</script>

<style>
  .contact-panel {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-panel__row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 6px 8px;
    background: rgba(13, 13, 13, 0.5);
    border: 1px solid rgba(232, 130, 10, 0.1);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .contact-panel__row:hover {
    border-color: rgba(232, 130, 10, 0.3);
    background: rgba(232, 130, 10, 0.04);
  }

  :global(html[data-theme="light"]) .contact-panel__row {
    background: var(--cyber-panel);
    border-color: var(--cyber-orange-dim);
  }

  :global(html[data-theme="light"]) .contact-panel__row:hover {
    background: var(--cyber-panel-alt);
    border-color: var(--cyber-orange);
  }

  .contact-panel__icon {
    display: flex;
    align-items: center;
    color: var(--cyber-text-dim);
    flex-shrink: 0;
    width: 20px;
    transition: color 0.15s;
  }

  .contact-panel__row:hover .contact-panel__icon {
    color: var(--cyber-orange);
  }

  .contact-panel__platform {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--cyber-text-dim);
    width: 72px;
    flex-shrink: 0;
  }

  .contact-panel__arrow {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: rgba(232, 130, 10, 0.3);
    width: 32px;
    flex-shrink: 0;
  }

  .contact-panel__value {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--cyber-text);
    flex: 1;
    text-align: right;
  }

  .contact-panel__row:hover .contact-panel__value {
    color: var(--cyber-orange);
  }
</style>
