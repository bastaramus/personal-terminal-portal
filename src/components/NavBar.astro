---
const now = new Date();
const buildDate = [
  now.getFullYear(),
  String(now.getMonth() + 1).padStart(2, "0"),
  String(now.getDate()).padStart(2, "0"),
].join(".");

const NAV_LINKS = [
  { label: "HOME", href: "/" },
  { label: "BLOG", href: "/blog" },
  { label: "PROJECTS", href: "/projects" },
  { label: "NOTES", href: "/notes" },
  { label: "TAGS", href: "/tags" },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <div class="navbar__inner">
    <div class="navbar__identity">
      <a href="/" class="navbar__logo">
        <span class="navbar__bracket">[</span>
        <span class="navbar__logo-name">xomenko.com</span>
        <span class="navbar__bracket">]</span>
      </a>
      <span class="navbar__prompt">&gt;_</span>
      <span class="navbar__name">DMYTRO KHOMENKO</span>
      <span class="navbar__sep">|</span>
      <span class="navbar__subtitle">PERSONAL TERMINAL v1.0</span>
      <span class="navbar__build">SYS.BUILD: {buildDate}</span>
    </div>

    <div class="navbar__links">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              "navbar__link",
              { "navbar__link--active": currentPath === link.href },
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 13, 13, 0.95);
    border-bottom: 1px solid var(--cyber-orange-dim);
    backdrop-filter: blur(8px);
  }

  .navbar::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--scanlines);
    pointer-events: none;
    z-index: 1;
  }

  .navbar__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .navbar__identity {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 1px;
    text-decoration: none;
    color: var(--cyber-orange);
    font-weight: 600;
  }

  .navbar__bracket {
    opacity: 0.5;
  }

  .navbar__logo-name {
    margin: 0 1px;
  }

  .navbar__prompt {
    color: var(--cyber-orange);
    font-size: 0.875rem;
    text-shadow: 0 0 8px var(--cyber-orange-glow);
  }

  .navbar__name {
    color: var(--cyber-orange);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-shadow: 0 0 8px var(--cyber-orange-glow), 0 0 20px rgba(232, 130, 10, 0.3);
  }

  .navbar__sep {
    color: var(--cyber-orange-dim);
    opacity: 0.6;
  }

  .navbar__subtitle {
    color: var(--cyber-text-dim);
    letter-spacing: 0.05em;
  }

  .navbar__build {
    color: var(--cyber-text-dim);
    opacity: 0.6;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .navbar__link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--cyber-text-dim);
    text-decoration: none;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    border: 1px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s,
      text-shadow 0.15s;
  }

  .navbar__link:hover,
  .navbar__link--active {
    color: var(--cyber-orange);
    border-color: var(--cyber-orange-dim);
    text-shadow: 0 0 8px var(--cyber-orange-glow);
  }

  /* ── Tablet: hide secondary identity text ── */
  @media (max-width: 1024px) {
    .navbar__subtitle,
    .navbar__build {
      display: none;
    }
  }

  /* ── Mobile: compact single row ── */
  @media (max-width: 640px) {
    .navbar__inner {
      height: auto;
      padding: 8px 12px;
      flex-wrap: wrap;
      gap: 8px;
    }

    .navbar__name,
    .navbar__sep,
    .navbar__subtitle,
    .navbar__build,
    .navbar__prompt {
      display: none;
    }

    .navbar__links {
      gap: 2px;
    }

    .navbar__link {
      padding: 4px 8px;
      font-size: 0.75rem;
    }
  }
</style>
