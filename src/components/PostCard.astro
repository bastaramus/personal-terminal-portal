---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  href: string;
}

const { title, description, pubDate, tags, href } = Astro.props;

const dateStr = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const toSlug = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---

<article class="post-card">
  <div class="post-card__body">
    <h3 class="post-card__title">
      <a href={href} class="post-card__title-link">{title}</a>
    </h3>
    <div class="post-card__tags">
      {tags.slice(0, 2).map((tag) => (
        <a href={`/tags/${toSlug(tag)}`} class="post-card__tag">#{tag}</a>
      ))}
    </div>
    <p class="post-card__desc">{description}</p>
    <div class="post-card__meta">
      <span class="post-card__date">{dateStr}</span>
      <a href={href} class="post-card__read">READ →</a>
    </div>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--cyber-panel-alt);
    border: 1px solid rgba(232, 130, 10, 0.15);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    border-color: rgba(232, 130, 10, 0.4);
    box-shadow: 0 0 16px rgba(232, 130, 10, 0.08);
  }

  .post-card__body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .post-card__title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .post-card__title::after {
    display: none;
  }

  .post-card__title-link {
    color: var(--cyber-text-bright);
    text-decoration: none;
  }

  .post-card:hover .post-card__title-link {
    color: var(--cyber-orange);
  }

  .post-card__tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .post-card__tag {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--cyber-orange);
    background: rgba(232, 130, 10, 0.06);
    border: 1px solid rgba(232, 130, 10, 0.25);
    padding: 1px 6px;
    font-family: var(--font-mono);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .post-card__tag:hover {
    background: rgba(232, 130, 10, 0.14);
    border-color: rgba(232, 130, 10, 0.5);
  }

  .post-card__desc {
    font-size: 0.82rem;
    color: var(--cyber-text-dim);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }

  .post-card__date {
    font-size: 0.875rem;
    color: var(--cyber-text-dim);
    font-family: var(--font-mono);
  }

  .post-card__read {
    font-size: 0.875rem;
    color: var(--cyber-orange);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-decoration: none;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .post-card:hover .post-card__read {
    opacity: 1;
  }
</style>
