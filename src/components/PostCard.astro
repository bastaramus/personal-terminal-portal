---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  href: string;
}

const { title, description, pubDate, tags, href } = Astro.props;

const dateStr = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={href} class="post-card">
  <div class="post-card__image">
    <div class="post-card__image-placeholder">
      <span class="post-card__image-label">IMG</span>
    </div>
  </div>
  <div class="post-card__body">
    <div class="post-card__tags">
      {tags.slice(0, 2).map((tag) => <span class="post-card__tag">{tag}</span>)}
    </div>
    <h3 class="post-card__title">{title}</h3>
    <p class="post-card__desc">{description}</p>
    <div class="post-card__meta">
      <span class="post-card__date">{dateStr}</span>
      <span class="post-card__read">READ →</span>
    </div>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--cyber-panel-alt);
    border: 1px solid rgba(232, 130, 10, 0.15);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    border-color: rgba(232, 130, 10, 0.4);
    box-shadow: 0 0 16px rgba(232, 130, 10, 0.08);
  }

  .post-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #0a0a0a;
    border-bottom: 1px solid rgba(232, 130, 10, 0.1);
  }

  .post-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(232, 130, 10, 0.02) 10px,
      rgba(232, 130, 10, 0.02) 20px
    );
  }

  .post-card__image-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(232, 130, 10, 0.2);
    letter-spacing: 0.2em;
  }

  .post-card__body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .post-card__tags {
    display: flex;
    gap: 4px;
  }

  .post-card__tag {
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: var(--cyber-orange);
    background: rgba(232, 130, 10, 0.06);
    border: 1px solid rgba(232, 130, 10, 0.25);
    padding: 1px 6px;
    font-family: var(--font-mono);
  }

  .post-card__title {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--cyber-text-bright);
    line-height: 1.4;
    margin: 0;
  }

  .post-card:hover .post-card__title {
    color: var(--cyber-orange);
  }

  .post-card__desc {
    font-size: 0.65rem;
    color: var(--cyber-text-dim);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .post-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }

  .post-card__date {
    font-size: 0.55rem;
    color: var(--cyber-text-dim);
    font-family: var(--font-mono);
  }

  .post-card__read {
    font-size: 0.55rem;
    color: var(--cyber-orange);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .post-card:hover .post-card__read {
    opacity: 1;
  }
</style>
